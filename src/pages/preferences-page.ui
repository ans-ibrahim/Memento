<?xml version="1.0" encoding="UTF-8"?>
<interface domain="memento">
  <requires lib="gtk" version="4.0" />
  <requires lib="Adw" version="1.0" />
  <template class="MementoPreferencesDialog" parent="AdwDialog">
    <property name="title" translatable="yes">Preferences</property>
    <property name="content-width">760</property>
    <property name="content-height">700</property>
    <property name="child">
      <object class="AdwToolbarView">
        <child type="top">
          <object class="AdwHeaderBar" />
        </child>
        <property name="content">
          <object class="AdwPreferencesPage">
            
            <!-- TMDB Configuration -->
            <child>
              <object class="AdwPreferencesGroup">
                <property name="title" translatable="yes">The Movie Database (TMDB)</property>
                <property name="description" translatable="yes">Configure your TMDB API key for movie and TV search</property>
                <child>
                  <object class="AdwEntryRow" id="api_key_row">
                    <property name="title" translatable="yes">API Key</property>
                    <property name="show-apply-button">true</property>
                    <signal name="apply" handler="_onApiKeyApply" swapped="no"/>
                  </object>
                </child>
                <child>
                  <object class="AdwActionRow">
                    <property name="title" translatable="yes">Get API Key</property>
                    <property name="subtitle" translatable="yes">Visit themoviedb.org to create a free account and generate an API key</property>
                    <property name="activatable">true</property>
                    <signal name="activated" handler="_onGetApiKeyActivated" swapped="no"/>
                    <child type="suffix">
                      <object class="GtkImage">
                        <property name="icon-name">adw-external-link-symbolic</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>

            <!-- Behavior Settings -->
            <child>
              <object class="AdwPreferencesGroup">
                <property name="title" translatable="yes">Behavior</property>
                <child>
                  <object class="AdwActionRow">
                    <property name="title" translatable="yes">Auto-remove from Watchlist</property>
                    <property name="subtitle" translatable="yes">Automatically remove titles from watchlist when you add a play</property>
                    <child type="suffix">
                      <object class="GtkSwitch" id="auto_remove_switch">
                        <property name="valign">center</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="AdwActionRow">
                    <property name="title" translatable="yes">Enable TMDB rating</property>
                    <property name="subtitle" translatable="yes">Show TMDB rating in the ratings section</property>
                    <child type="suffix">
                      <object class="GtkSwitch" id="tmdb_rating_switch">
                        <property name="valign">center</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="AdwActionRow">
                    <property name="title" translatable="yes">Enable IMDb rating</property>
                    <property name="subtitle" translatable="yes">Fetch and show IMDb rating in the ratings section</property>
                    <child type="suffix">
                      <object class="GtkSwitch" id="imdb_rating_switch">
                        <property name="valign">center</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="AdwActionRow">
                    <property name="title" translatable="yes">People metric default</property>
                    <property name="subtitle" translatable="yes">Choose the default metric used on dashboard and Top People page</property>
                    <child type="suffix">
                      <object class="GtkDropDown" id="people_metric_dropdown">
                        <property name="valign">center</property>
                        <property name="model">
                          <object class="GtkStringList">
                            <items>
                              <item translatable="yes">Total plays</item>
                              <item translatable="yes">Unique titles</item>
                            </items>
                          </object>
                        </property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="AdwActionRow">
                    <property name="title" translatable="yes">TV people counting level</property>
                    <property name="subtitle" translatable="yes">Count TV contribution by episodes instead of TV shows</property>
                    <child type="suffix">
                      <object class="GtkSwitch" id="people_tv_episode_level_switch">
                        <property name="valign">center</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>

            <!-- Data Settings -->
            <child>
              <object class="AdwPreferencesGroup">
                <property name="title" translatable="yes">Data</property>
                <child>
                  <object class="AdwActionRow" id="refresh_movies_row">
                    <property name="title" translatable="yes">Refresh all titles</property>
                    <property name="subtitle" translatable="yes">Re-download details and credits for every saved movie or TV show</property>
                    <child type="suffix">
                      <object class="GtkButton" id="refresh_all_button">
                        <property name="label" translatable="yes">Refresh</property>
                        <property name="valign">center</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="AdwActionRow" id="refresh_imdb_ratings_row">
                    <property name="title" translatable="yes">Refresh all IMDb ratings</property>
                    <property name="subtitle" translatable="yes">Update cached IMDb ratings for all saved titles</property>
                    <child type="suffix">
                      <object class="GtkButton" id="refresh_imdb_ratings_button">
                        <property name="label" translatable="yes">Refresh</property>
                        <property name="valign">center</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="AdwActionRow" id="refresh_progress_row">
                    <property name="title" translatable="yes">Refresh progress</property>
                    <property name="visible">false</property>
                    <child type="suffix">
                      <object class="GtkBox">
                        <property name="orientation">horizontal</property>
                        <property name="hexpand">true</property>
                        <property name="halign">fill</property>
                        <child>
                          <object class="GtkProgressBar" id="refresh_progress_bar">
                            <property name="hexpand">true</property>
                            <property name="show-text">true</property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="AdwActionRow" id="export_backup_row">
                    <property name="title" translatable="yes">Export backup</property>
                    <property name="subtitle" translatable="yes">Export settings and database into a .backup file</property>
                    <child type="suffix">
                      <object class="GtkButton" id="export_backup_button">
                        <property name="label" translatable="yes">Export</property>
                        <property name="valign">center</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="AdwActionRow" id="import_backup_row">
                    <property name="title" translatable="yes">Import backup</property>
                    <property name="subtitle" translatable="yes">Restore settings and database from a .backup file</property>
                    <child type="suffix">
                      <object class="GtkButton" id="import_backup_button">
                        <property name="label" translatable="yes">Import</property>
                        <property name="valign">center</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="AdwActionRow" id="import_ticketbooth_row">
                    <property name="title" translatable="yes">Import Ticket Booth</property>
                    <property name="subtitle" translatable="yes">Import watchlist and watched titles from a Ticket Booth .zip export</property>
                    <child type="suffix">
                      <object class="GtkButton" id="import_ticketbooth_button">
                        <property name="label" translatable="yes">Import</property>
                        <property name="valign">center</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="AdwActionRow" id="import_movary_row">
                    <property name="title" translatable="yes">Import Movary</property>
                    <property name="subtitle" translatable="yes">Import watched titles from history.csv or watchlist from watchlist.csv</property>
                    <child type="suffix">
                      <object class="GtkButton" id="import_movary_button">
                        <property name="label" translatable="yes">Import</property>
                        <property name="valign">center</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="AdwActionRow" id="refresh_imdb_progress_row">
                    <property name="title" translatable="yes">IMDb refresh progress</property>
                    <property name="visible">false</property>
                    <child type="suffix">
                      <object class="GtkBox">
                        <property name="orientation">horizontal</property>
                        <property name="hexpand">true</property>
                        <property name="halign">fill</property>
                        <child>
                          <object class="GtkProgressBar" id="refresh_imdb_progress_bar">
                            <property name="hexpand">true</property>
                            <property name="show-text">true</property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>

          </object>
        </property>
      </object>
    </property>
  </template>
</interface>
